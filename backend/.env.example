# 高德地图API Key (必须)
# 申请地址: https://lbs.amap.com/
AMAP_API_KEY=your_amap_api_key_here

# LLM服务配置 (支持 OpenAI 兼容 API)
# 推荐: Xiaomi MiMo (https://token-plan-cn.xiaomimimo.com/v1)
# 备选: DeepSeek (https://api.deepseek.com/v1)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL_ID=mimo-v2.5-pro

# Unsplash 图片 (可选)
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# Amadeus 航班API (可选，用于实时航班查询)
# 免费注册: https://developers.amadeus.com/register
# 每月2000次免费调用
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# CORS 允许的源 (可选，逗号分隔)
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# JWT 认证 (生产环境务必修改)
JWT_SECRET=dev-secret-change-in-production

# 限流 (可选)
RATE_LIMIT_REQUESTS=10

# 服务器配置 (可选)
HOST=0.0.0.0
PORT=8000
DEBUG=true
